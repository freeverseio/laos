                        }
                      ],
                      "index": 28,
                      "name": "hotfix_remove_delegation_requests_exited_candidates"
                    },
                    {
                      "docs": [
                        "Notify a collator is inactive during MaxOfflineRounds"
                      ],
                      "fields": [
                        {
                          "name": "collator",
                          "type": 0,
                          "typeName": "T::AccountId"
                        }
                      ],
                      "index": 29,
