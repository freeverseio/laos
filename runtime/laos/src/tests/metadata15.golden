                      "index": 14,
                      "name": "LowBalance"
                    },
                    {
                      "docs": [
                        "The asset owner has too many locks on the asset."
                      ],
                      "index": 15,
                      "name": "TooManyLocks"
                    },
                    {
                      "docs": [
                        "The given account is not an identifiable sovereign account for any location."
                      ],
                      "index": 16,
                      "name": "AccountNotSovereign"
                    },
                    {
